# ── Retell ────────────────────────────────────────────────────────────────
# Dashboard → API Keys. Used for agent management, webhook HMAC verification,
# and the eval harness (Get Call / Simulation APIs).
RETELL_API_KEY=key_xxxxxxxxxxxxxxxxxxxx

# ── OpenAI (eval simulated patient + judges + call summaries) ─────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ── Cliniko ───────────────────────────────────────────────────────────────
# My Info → API Keys. The key's shard is its suffix, e.g. "...-au1".
# The generating user needs Administrator + Practitioner roles (else 403).
CLINIKO_API_KEY=xxxxxxxxxxxxxxxxxxxx-au1
# Mandatory User-Agent identification per Cliniko API policy:
CLINIKO_VENDOR_NAME=clinic-voice-agent
CLINIKO_VENDOR_EMAIL=you@example.com

# ── Database (Neon Postgres, AWS us-west-2) ───────────────────────────────
# Pooled connection string (app runtime; goes through PgBouncer):
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx-pooler.us-west-2.aws.neon.tech/neondb
# Direct (non-pooled) connection string (alembic migrations):
DATABASE_URL_DIRECT=postgresql+asyncpg://user:pass@ep-xxx.us-west-2.aws.neon.tech/neondb

# ── App ───────────────────────────────────────────────────────────────────
# Public base URL of the deployed backend (no trailing slash), e.g. Fly app URL:
APP_BASE_URL=https://clinic-voice-agent.fly.dev
# Shared secret Retell sends in the X-Tool-Secret header on tool calls:
TOOL_SHARED_SECRET=generate-a-long-random-string
# Clinic-local timezone (IANA):
CLINIC_TZ=Asia/Kolkata

# ── Caller identity verification (OTP) ────────────────────────────────────
# Existing-appointment disclosure/changes require an SMS OTP to the number on
# file. Flip to true only when the published agent has the verification tools
# (see README rollout note); demo/eval numbers (+919000000…) use a fixed dev
# code instead of real SMS.
REQUIRE_VERIFICATION=false

# ── Twilio ────────────────────────────────────────────────────────────────
# PSTN number import (scripts/import_twilio_number.py) + OTP delivery via
# Twilio Verify (scripts/setup_twilio_verify.py creates the service and
# prints the SID below).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ── Retell agent wiring (filled in after `python -m agent.agent_config sync`) ─
RETELL_AGENT_ID=
RETELL_PHONE_NUMBER=
# Optional: force a specific TTS voice (else auto-picks a female Hindi/Hinglish voice).
# Browse candidates with: python -m agent.agent_config voices
RETELL_VOICE_ID=
